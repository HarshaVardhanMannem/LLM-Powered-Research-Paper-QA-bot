# NVIDIA API (required for embeddings/LLM)

NVIDIA_API_KEY=your-nvidia-api-key

# PostgreSQL (used by Docker Compose; override for local Postgres)
POSTGRES_DB=research_qa
POSTGRES_HOST=localhost
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433
POSTGRES_USER=postgres

# JWT for auth (set a strong secret in production)
JWT_SECRET_KEY=change-me-in-production

# Extraction and Knowledge Bases
EXTRACTION_MODE=structure
# Defaults include ML, NLP, Computer Vision, AI, and Information Retrieval.
# PREDEFINED_KB_DOMAINS=ML,NLP,Computer Vision,AI,Information Retrieval
PREDEFINED_KB_YEARS=2026,2025
PREDEFINED_KB_INCLUDE_LATEST=true
PREDEFINED_KB_MAX_PAPERS=5
# Domain -> arXiv categories used for category/year KBs.
# Defaults are built in. Override with JSON if needed, e.g.
# PREDEFINED_KB_ARXIV_CATEGORIES='{"ML":["cs.LG","stat.ML"],"NLP":["cs.CL"]}'
# Optional: JSON mapping domain -> arXiv IDs for seed ingest, e.g.
# PREDEFINED_KB_PAPER_IDS={"ML":["1706.03762"],"NLP":["1810.04805"]}
# Optional: full custom specs for system KBs.
# PREDEFINED_KB_SPECS=[{"name":"NLP Research 2024","domain":"NLP","arxiv_categories":["cs.CL"],"year":2024,"max_papers":10}]

# Qdrant (optional; used when running with docker-compose)
QDRANT_COLLECTION_NAME=research_papers
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_VECTOR_SIZE=1024
