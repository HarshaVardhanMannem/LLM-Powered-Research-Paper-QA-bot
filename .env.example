# NVIDIA API (required for embeddings/LLM)

NVIDIA_API_KEY=your-nvidia-api-key

# PostgreSQL (used by Docker Compose; override for local Postgres)
POSTGRES_DB=research_qa
POSTGRES_HOST=localhost
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433
POSTGRES_USER=postgres

# JWT for auth (set a strong secret in production)
JWT_SECRET_KEY=change-me-in-production

# Extraction and Knowledge Bases
EXTRACTION_MODE=structure
PREDEFINED_KB_YEARS=2026,2025
PREDEFINED_KB_INCLUDE_LATEST=true
PREDEFINED_KB_MAX_PAPERS=5
# Default KB domains and arXiv category mappings are defined in code.
# Override advanced JSON settings in a local .env file when needed.

# Qdrant (optional; used when running with docker-compose)
QDRANT_COLLECTION_NAME=research_papers
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_VECTOR_SIZE=1024
